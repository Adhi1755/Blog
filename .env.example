# ── Frontend ──────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Points the frontend at the backend API.
# Local dev → localhost; Production (Vercel) → Render URL
NEXT_PUBLIC_API_URL=http://localhost:5001

# ── Backend (Flask) ───────────────────────────────────────────
PORT=5001
FLASK_ENV=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Authentication Secrets (CHANGE IN PRODUCTION) ────────────
JWT_SECRET_KEY=blogspace-dev-secret-change-in-prod

# ── Database (Future-proofing for backend migration) ─────────
# DATABASE_URL=postgresql://user:password@localhost:5432/blogspace

# ── Third Party APIs (Optional) ──────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=
