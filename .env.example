# ── Frontend ──────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Backend (Flask) ───────────────────────────────────────────
PORT=5001
FLASK_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Authentication Secrets (CHANGE IN PRODUCTION) ────────────
JWT_SECRET_KEY=blogspace-dev-secret-change-in-prod

# ── Database (Future-proofing for backend migration) ─────────
# DATABASE_URL=postgresql://user:password@localhost:5432/blogspace

# ── Third Party APIs (Optional) ──────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=
